// SmarterSprint — Prisma Schema
// PostgreSQL · multi-tenant ready · auditable

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────── Enums ───────────────

enum Role {
  ADMIN
  CTO
  CFO
  CEO
  ENGINEERING_MANAGER
  USER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum RepoProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum CostBand {
  JUNIOR
  MID
  SENIOR
  LEAD
  STAFF
  PRINCIPAL
}

enum ScenarioCategory {
  BASELINE
  AGGRESSIVE
  CONSERVATIVE
  RISK_ADJUSTED
  CUSTOM
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  RUN_FORECAST
  RUN_DEBATE
  GENERATE_REPORT
}

enum AIProviderKind {
  GEMINI
  OPENAI
  ANTHROPIC
  LOCAL
}

// ─────────────── Core ───────────────

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  firstName    String?
  lastName     String?
  role         Role        @default(USER)
  status       UserStatus  @default(ACTIVE)
  lastLoginAt  DateTime?
  refreshToken String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  auditLogs    AuditLog[]
  reports      Report[]
}

model Project {
  id           String         @id @default(uuid())
  name         String
  description  String?
  status       ProjectStatus  @default(PLANNING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  repositories Repository[]
  sprints      Sprint[]
  scenarios    Scenario[]
}

model Repository {
  id         String       @id @default(uuid())
  projectId  String
  provider   RepoProvider
  url        String
  externalId String?
  createdAt  DateTime     @default(now())

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Sprint {
  id        String   @id @default(uuid())
  projectId String
  name      String
  startDate DateTime
  endDate   DateTime
  velocity  Float    @default(0)
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Developer {
  id         String        @id @default(uuid())
  pseudonym  String        @unique
  department String
  costBand   CostBand
  hourlyRate Float
  capacity   Float         @default(1.0)
  createdAt  DateTime      @default(now())

  skills     DeveloperSkill[]
  allocations Allocation[]
}

model Skill {
  id        String           @id @default(uuid())
  name      String           @unique
  category  String?
  createdAt DateTime         @default(now())

  developers DeveloperSkill[]
}

model DeveloperSkill {
  developerId String
  skillId     String
  proficiency Int      @default(3) // 1-5

  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([developerId, skillId])
}

model Scenario {
  id          String            @id @default(uuid())
  projectId   String
  name        String
  category    ScenarioCategory  @default(BASELINE)
  assumptions Json
  createdBy   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allocations Allocation[]
  forecasts   Forecast[]
  debates     Debate[]

  @@index([projectId])
}

model Allocation {
  id                 String   @id @default(uuid())
  developerId        String
  scenarioId         String
  allocationPercent  Float
  startDate          DateTime
  endDate            DateTime
  notes              String?
  createdAt          DateTime @default(now())

  developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  scenario  Scenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@index([developerId])
}

model Forecast {
  id               String   @id @default(uuid())
  scenarioId       String
  timelineDays     Int
  cost             Float
  riskAdjustedCost Float
  confidence       Float
  breakdown        Json
  createdAt        DateTime @default(now())

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}

model Debate {
  id              String   @id @default(uuid())
  scenarioId      String
  confidenceScore Float
  frictionFactor  Float
  summary         String
  transcript      Json
  createdAt       DateTime @default(now())

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  risks    Risk[]

  @@index([scenarioId])
}

model Risk {
  id          String        @id @default(uuid())
  debateId    String
  title       String
  description String
  severity    RiskSeverity
  likelihood  Float
  impact      Float
  mitigation  String?
  createdAt   DateTime      @default(now())

  debate Debate @relation(fields: [debateId], references: [id], onDelete: Cascade)

  @@index([debateId])
}

model AuditLog {
  id          String      @id @default(uuid())
  action      AuditAction
  entity      String
  entityId    String?
  performedBy String?
  payload     Json?
  ip          String?
  userAgent   String?
  timestamp   DateTime    @default(now())

  user User? @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([performedBy])
  @@index([timestamp])
}

model Report {
  id         String   @id @default(uuid())
  title      String
  kind       String
  payload    Json
  generatedBy String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [generatedBy], references: [id], onDelete: SetNull)
}

// ─────────────── AI ───────────────

model AIRequest {
  id        String         @id @default(uuid())
  provider  AIProviderKind
  model     String
  purpose   String
  prompt    String
  metadata  Json?
  createdAt DateTime       @default(now())

  responses AIResponse[]
}

model AIResponse {
  id           String   @id @default(uuid())
  requestId    String
  output       String
  latencyMs    Int
  inputTokens  Int?
  outputTokens Int?
  finishReason String?
  metadata     Json?
  createdAt    DateTime @default(now())

  request AIRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}
