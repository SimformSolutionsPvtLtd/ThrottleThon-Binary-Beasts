// SmarterSprint — Phase 0 multi-tenant schema
// Every tenant-scoped table carries tenantId; queries MUST be scoped via TenantGuard.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────── Enums

enum Plan {
  FREE
  STARTER
  ENTERPRISE
}

enum CostBand {
  C1
  C2
  C3
  C4
  C5
}

enum AiCacheType {
  INGESTION_JIRA
  INGESTION_GIT
  INGESTION_HRMS
  DEBATE
}

// ─────────────── Global

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships   TenantMembership[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Permission {
  id          String   @id @default(cuid())
  action      String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

// ─────────────── Tenant

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  brandName    String   @map("brand_name")
  logoUrl      String?  @map("logo_url")
  primaryColor String   @default("#2563EB") @map("primary_color")
  plan         Plan     @default(FREE)
  settings     Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships       TenantMembership[]
  roles             Role[]
  refreshTokens     RefreshToken[]
  developers        Developer[]
  pseudonymMaps     PseudonymMap[]
  jiraTickets       JiraTicket[]
  gitRepositories   GitRepository[]
  scenarios         Scenario[]
  multiplierConfigs MultiplierConfig[]
  allocations       Allocation[]
  aiCaches          AiCache[]
  debateResults     DebateResult[]
  forecastResults   ForecastResult[]
  auditLogs         AuditLog[]

  @@map("tenants")
}

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  roleId    String   @map("role_id")
  isActive  Boolean  @default(true) @map("is_active")
  joinedAt  DateTime @default(now()) @map("joined_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@map("tenant_memberships")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  memberships TenantMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─────────────── Tenant-scoped data

model Developer {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  pseudonym         String
  role              String
  department        String
  tenureYears       Float    @map("tenure_years")
  costBand          CostBand @map("cost_band")
  skills            Json     @default("[]")
  currentAllocation Json     @default("{}") @map("current_allocation")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pseudonym])
  @@index([tenantId])
  @@map("developers")
}

model PseudonymMap {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  pseudonym String
  realName  String   @map("real_name")
  email     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pseudonym])
  @@index([tenantId])
  @@map("pseudonym_maps")
}

model JiraTicket {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  externalId         String   @map("external_id")
  title              String
  estimatedPoints    Int      @map("estimated_points")
  actualPoints       Int      @map("actual_points")
  assigneePseudonym  String   @map("assignee_pseudonym")
  labels             String[]
  sprint             String
  status             String
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([tenantId, sprint])
  @@map("jira_tickets")
}

model GitRepository {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  name           String
  defaultBranch  String   @map("default_branch")
  language       String
  framework      String
  metadata       Json     @default("{}")
  staticAnalysis Json     @default("{}") @map("static_analysis")
  dependencies   Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("git_repositories")
}

model Scenario {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  externalId        String   @map("external_id")
  name              String
  description       String
  category          String
  baseEffortPoints  Int      @map("base_effort_points")
  config            Json     @default("{}")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@map("scenarios")
}

model MultiplierConfig {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  version   String
  config    Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
  @@index([tenantId])
  @@map("multiplier_configs")
}

model Allocation {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  devPseudonym        String   @map("dev_pseudonym")
  scenarioExternalId  String   @map("scenario_external_id")
  allocationPercent   Int      @map("allocation_percent")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, devPseudonym, scenarioExternalId])
  @@index([tenantId])
  @@map("allocations")
}

model AiCache {
  id        String      @id @default(cuid())
  tenantId  String      @map("tenant_id")
  cacheKey  String      @map("cache_key")
  cacheType AiCacheType @map("cache_type")
  data      Json
  expiresAt DateTime    @map("expires_at")
  createdAt DateTime    @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cacheKey])
  @@index([tenantId])
  @@index([tenantId, cacheKey, expiresAt])
  @@map("ai_cache")
}

model DebateResult {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  scenarioExternalId String   @map("scenario_external_id")
  frictionFactor     Float    @map("friction_factor")
  confidenceScore    Float    @map("confidence_score")
  keyRisks           Json     @map("key_risks")
  debateLog          Json     @map("debate_log")
  isFixture          Boolean  @default(false) @map("is_fixture")
  createdAt          DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("debate_results")
}

model ForecastResult {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  scenarioExternalId String   @map("scenario_external_id")
  parameters         Json
  result             Json
  createdAt          DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("forecast_results")
}

model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  userId        String?  @map("user_id")
  action        String
  resource      String
  details       Json     @default("{}")
  piiSanitised  Boolean  @default(true) @map("pii_sanitised")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}
